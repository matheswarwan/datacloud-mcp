# Salesforce Connected App credentials (client credentials flow)
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=yourpassword
SF_LOGIN_URL=https://yourorg.my.salesforce.com

# Optional: token expiry buffer in seconds (default: 300 = 5 minutes)
# TOKEN_EXPIRY_BUFFER=300
