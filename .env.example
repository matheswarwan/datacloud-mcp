# ── Auth method ────────────────────────────────────────────────────────────────
# Choose one: client_credentials | jwt | oauth_code
SF_AUTH_METHOD=client_credentials

# ── Shared ─────────────────────────────────────────────────────────────────────
SF_CLIENT_ID=your_connected_app_consumer_key
SF_LOGIN_URL=https://yourorg.my.salesforce.com

# ── client_credentials (default) ───────────────────────────────────────────────
# Connected App must have client credentials flow enabled.
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=yourpassword

# ── jwt (server-to-server) ─────────────────────────────────────────────────────
# Connected App must have JWT Bearer flow enabled and user pre-authorised.
# SF_AUTH_METHOD=jwt
# SF_PRIVATE_KEY_PATH=/absolute/path/to/server.key
# SF_USERNAME=your_salesforce_username@example.com

# ── oauth_code (interactive browser login) ─────────────────────────────────────
# User is redirected to Salesforce login; tokens are stored in memory.
# Connected App must have callback URL: http://localhost:3456/callback
# SF_AUTH_METHOD=oauth_code
# SF_CLIENT_SECRET=your_connected_app_consumer_secret
# SF_CALLBACK_PORT=3456   # optional, defaults to 3456

# ── Optional ────────────────────────────────────────────────────────────────────
# Token expiry buffer in seconds (default: 300 = re-auth 5 min before expiry)
# TOKEN_EXPIRY_BUFFER=300
